# Multi-stage build for telemetry-collector
FROM golang:1.26-alpine AS builder

# Install build dependencies
# Including git for module resolution and ca-certificates for secure downloads
RUN apk add --no-cache git make ca-certificates

WORKDIR /build

# Copy go mod files first to cache dependencies
COPY go.mod go.sum* ./

# Download dependencies - this ensures consistent protobuf/gRPC versions
RUN go mod download

# Copy source code
COPY . .

# Build collector binary
# Using CGO_ENABLED=0 for static binary portability
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-w -s" \
    -o telemetry-collector \
    ./cmd/collector

# Runtime stage
FROM alpine:3.18

# Install runtime dependencies
RUN apk add --no-cache ca-certificates tzdata

# Create non-root user
RUN addgroup -g 1000 telemetry && \
    adduser -D -u 1000 -G telemetry telemetry

# Create data directory
RUN mkdir -p /data && \
    chown telemetry:telemetry /data

WORKDIR /home/telemetry

# Copy binary from builder
COPY --from=builder --chown=telemetry:telemetry /build/telemetry-collector .

# Switch to non-root user
USER telemetry

# Health check (adjust port as needed)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:8081/health || exit 1

# Expose ports for metrics and health checks
EXPOSE 8081

# Run application
ENTRYPOINT ["./telemetry-collector"]
